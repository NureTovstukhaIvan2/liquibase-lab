<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        User Service — roles table
        Author: tovstukha
        Reference table for user roles: USER, ADMIN, MODERATOR.
        Unique constraint on name prevents duplicate role definitions.
    -->
    <changeSet id="002-create-roles-table" author="tovstukha">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="roles"/></not>
        </preConditions>
        <comment>Create roles reference table for User Service</comment>

        <createTable tableName="roles">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_roles"/>
            </column>
            <column name="name" type="NVARCHAR(50)">
                <constraints nullable="false" unique="true" uniqueConstraintName="UQ_roles_name"/>
            </column>
            <column name="description" type="NVARCHAR(255)"/>
        </createTable>

        <!-- ============================================================== -->
        <!-- SYSTEM REGISTRATION — DO NOT MODIFY                            -->
        <!-- ============================================================== -->
        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'roles', 'REFERENCE_TABLE', 'tovstukha', 1, 'user_service',
                    'Reference table of user roles: USER, ADMIN, MODERATOR.',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('roles')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'roles';</sql>
            <dropTable tableName="roles"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
