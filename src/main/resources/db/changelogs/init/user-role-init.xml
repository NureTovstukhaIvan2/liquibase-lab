<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        User Service — user_role join table
        Author: tovstukha
        Implements M:N between users and roles via composite PK.
        CASCADE DELETE on both FKs: removing a user or role
        automatically removes all related user_role rows.
    -->
    <changeSet id="003-create-user-role-table" author="tovstukha">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="user_role"/></not>
        </preConditions>
        <comment>Create user_role join table (M:N users-roles)</comment>

        <createTable tableName="user_role">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="role_id" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="user_role"
                       columnNames="user_id, role_id"
                       constraintName="PK_user_role"/>

        <addForeignKeyConstraint
                baseTableName="user_role" baseColumnNames="user_id"
                referencedTableName="users" referencedColumnNames="id"
                constraintName="FK_user_role_user"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="user_role" baseColumnNames="role_id"
                referencedTableName="roles" referencedColumnNames="id"
                constraintName="FK_user_role_role"
                onDelete="CASCADE"/>

        <!-- ============================================================== -->
        <!-- SYSTEM REGISTRATION — DO NOT MODIFY                            -->
        <!-- ============================================================== -->
        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'user_role', 'JOIN_TABLE', 'tovstukha', 1, 'user_service',
                    'M:N join between users and roles. Composite PK. CASCADE DELETE on both FKs.',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('user_role')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'user_role';</sql>
            <dropTable tableName="user_role"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
