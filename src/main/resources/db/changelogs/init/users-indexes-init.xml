<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        User Service — indexes for users table
        Author: tovstukha
        Additional non-unique index on email to speed up login lookups.
        username and email already have UNIQUE constraints (implicit unique indexes),
        but an explicit index on email improves partial-match query performance.
    -->
    <changeSet id="004-create-users-indexes" author="tovstukha">
        <comment>Create performance indexes on users table</comment>

        <createIndex tableName="users" indexName="idx_users_email">
            <column name="email"/>
        </createIndex>

        <createIndex tableName="users" indexName="idx_users_is_active">
            <column name="is_active"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="users" indexName="idx_users_email"/>
            <dropIndex tableName="users" indexName="idx_users_is_active"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
